<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.smartcourse.controller.AdminDashboardController"
            prefWidth="1100" prefHeight="700" styleClass="root">

    <left>
        <VBox styleClass="sidebar" spacing="0" prefWidth="210" alignment="TOP_CENTER">
            <padding><Insets top="28" right="14" bottom="28" left="14"/></padding>
            <VBox alignment="CENTER" spacing="4">
                <Label text="🎓 SCR Portal" styleClass="sidebar-logo"/>
                <Label text="ADMIN" styleClass="sidebar-subtitle"/>
            </VBox>
            <Separator style="-fx-padding: 16 0;"/>
            <VBox spacing="0" VBox.vgrow="ALWAYS">
                <padding><Insets top="16"/></padding>
                <Button text="📊  Dashboard" styleClass="nav-btn" onAction="#showDashboard" maxWidth="Infinity"/>
                <Button text="🏛️  Academic Structure" styleClass="nav-btn" onAction="#showCourses" maxWidth="Infinity"/>
                <Button text="👥  Manage Users" styleClass="nav-btn" onAction="#showUsers" maxWidth="Infinity"/>
                <Button text="📅  Scheduling" styleClass="nav-btn" onAction="#showScheduling" maxWidth="Infinity"/>
                <Button text="📋  All Registrations" styleClass="nav-btn" onAction="#showRegistrations" maxWidth="Infinity"/>
            </VBox>
            <VBox spacing="8" alignment="BOTTOM_CENTER">
                <VBox styleClass="user-badge" spacing="2" alignment="CENTER">
                    <Label fx:id="sidebarName" text="Admin" styleClass="user-name"/>
                    <Label fx:id="sidebarEmail" text="" style="-fx-font-size:11px; -fx-text-fill:#64748b;"/>
                </VBox>
                <Button text="🚪  Logout" styleClass="btn-danger" onAction="#handleLogout" maxWidth="Infinity"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentPane" styleClass="content-area"/>
    </center>
</BorderPane>
